[Unit]
Description=Workflow IA FastAPI service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=www-data
WorkingDirectory=ROOT_PATH_PLACEHOLDER/backend
Environment=PYTHONPATH=ROOT_PATH_PLACEHOLDER/backend
ExecStart=ROOT_PATH_PLACEHOLDER/backend/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
